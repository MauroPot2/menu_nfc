rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Chiunque può leggere (es. i clienti vedono il menu)
    // Solo gli utenti autenticati (amministratori) possono scrivere
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
